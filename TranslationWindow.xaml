<Window x:Class="ClickToTranslate.TranslationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="תרגום" Height="400" Width="460"
        Icon="icon.ico"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        MinWidth="340" MinHeight="280"
        FlowDirection="RightToLeft"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <!-- סגנון כפתור פעולה (בסרגל הכלים התחתון) -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource CardHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentDarkBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- כפתור סגירה עגול -->
        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource DangerBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox קומפקטי לשפה בסרגל התחתון -->
        <Style x:Key="CompactComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>
    </Window.Resources>

    <!-- מסגרת עגולת פינות עם צל -->
    <Border Background="{StaticResource BgBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="12">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="22" ShadowDepth="3" Opacity="0.55"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- שורת כותרת -->
                <RowDefinition Height="Auto"/>  <!-- טקסט מקור -->
                <RowDefinition Height="*"/>     <!-- תרגום -->
                <RowDefinition Height="Auto"/>  <!-- שורת פעולות -->
            </Grid.RowDefinitions>

            <!-- שורת כותרת - ניתן לגרור -->
            <Border Grid.Row="0"
                    Background="{StaticResource CardBrush}"
                    CornerRadius="12,12,0,0"
                    Padding="14,10"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🌐"
                                   FontSize="16"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock x:Name="TitleText"
                                   Text="תרגום מהיר"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   VerticalAlignment="Center"/>
                        <Border Background="{StaticResource BgBrush}"
                                CornerRadius="10"
                                Padding="8,3"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="EngineLabel"
                                       Text=""
                                       FontSize="10"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource CloseButton}"
                            Content="✕"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- טקסט מקור -->
            <Border Grid.Row="1"
                    Background="{StaticResource CardBrush}"
                    Margin="14,12,14,6"
                    CornerRadius="8"
                    Padding="12,10">
                <StackPanel>
                    <TextBlock Text="טקסט מקור"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SubtleTextBrush}"
                               Margin="0,0,0,6"/>
                    <ScrollViewer MaxHeight="80" VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="SourceTextBox"
                                 Style="{StaticResource InlineTextBox}"
                                 Foreground="{StaticResource TextBrush}"
                                 FontSize="13"
                                 TextWrapping="Wrap"
                                 IsReadOnly="False"
                                 AcceptsReturn="True"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- תוצאת תרגום -->
            <Border Grid.Row="2"
                    Background="{StaticResource CardBrush}"
                    Margin="14,6,14,6"
                    CornerRadius="8"
                    Padding="12,10">
                <Grid>
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="תרגום"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="DetectedLangLabel"
                                       Text=""
                                       FontSize="10"
                                       Foreground="{StaticResource SubtleTextBrush}"/>
                        </Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="180">
                            <TextBox x:Name="TranslatedTextBox"
                                     Style="{StaticResource InlineTextBox}"
                                     Foreground="{StaticResource TextBrush}"
                                     FontSize="15"
                                     TextWrapping="Wrap"
                                     IsReadOnly="True"
                                     Text=""/>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- אינדיקטור טעינה -->
                    <StackPanel x:Name="LoadingPanel"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="Visible">
                        <!-- ספינר מסתובב -->
                        <Grid Width="32" Height="32" HorizontalAlignment="Center">
                            <Ellipse Stroke="{StaticResource BorderBrush}"
                                     StrokeThickness="3"/>
                            <Ellipse x:Name="SpinnerArc"
                                     Stroke="{StaticResource AccentBrush}"
                                     StrokeThickness="3"
                                     StrokeDashArray="4 8"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Ellipse.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 From="0" To="360"
                                                                 Duration="0:0:1"
                                                                 RepeatBehavior="Forever"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                        </Grid>
                        <TextBlock Text="מתרגם..."
                                   FontSize="12"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- שורת פעולות תחתונה -->
            <Grid Grid.Row="3" Margin="14,6,14,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- בחירת שפת יעד -->
                <ComboBox x:Name="TargetLangCombo"
                          Grid.Column="0"
                          Width="140"
                          Style="{StaticResource CompactComboBox}"
                          MaxDropDownHeight="260"
                          SelectionChanged="TargetLangCombo_SelectionChanged"/>

                <!-- כפתורים -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Style="{StaticResource IconButton}"
                            Content="📋 העתק"
                            Click="CopyButton_Click"
                            Margin="0,0,4,0"/>
                    <Button Style="{StaticResource IconButton}"
                            Content="🔄 תרגם שוב"
                            Click="RetranslateButton_Click"
                            Margin="0,0,4,0"/>
                    <Button Style="{StaticResource IconButton}"
                            Content="⚙️"
                            ToolTip="הגדרות"
                            Click="SettingsButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
