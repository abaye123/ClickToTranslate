<Window x:Class="ClickToTranslate.TranslationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="תרגום" Height="380" Width="440"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        MinWidth="320" MinHeight="260"
        FlowDirection="RightToLeft">

    <Window.Resources>
        <!-- צבעים -->
        <SolidColorBrush x:Key="BgBrush" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="CardBrush" Color="#2A2A3C"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#89B4FA"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#A5C4FA"/>
        <SolidColorBrush x:Key="TextBrush" Color="#CDD6F4"/>
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#9399B2"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#45475A"/>

        <!-- סגנון כפתור פעולה -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3C3C52"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- סגנון כפתור סגירה -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E06C75"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- מסגרת עגולת פינות עם צל -->
    <Border Background="{StaticResource BgBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="3" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- שורת כותרת -->
                <RowDefinition Height="Auto"/>  <!-- טקסט מקור -->
                <RowDefinition Height="*"/>     <!-- תרגום -->
                <RowDefinition Height="Auto"/>  <!-- שורת פעולות -->
            </Grid.RowDefinitions>

            <!-- שורת כותרת - ניתן לגרור -->
            <Border Grid.Row="0"
                    Background="{StaticResource CardBrush}"
                    CornerRadius="12,12,0,0"
                    Padding="14,10"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🌐"
                                   FontSize="16"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock x:Name="TitleText"
                                   Text="תרגום מהיר"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="EngineLabel"
                                   Text=""
                                   FontSize="11"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource CloseButton}"
                            Content="✕"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- טקסט מקור -->
            <Border Grid.Row="1"
                    Background="{StaticResource CardBrush}"
                    Margin="14,12,14,6"
                    CornerRadius="8"
                    Padding="12,10">
                <StackPanel>
                    <TextBlock Text="טקסט מקור"
                               FontSize="10"
                               Foreground="{StaticResource SubtleTextBrush}"
                               Margin="0,0,0,4"/>
                    <ScrollViewer MaxHeight="80" VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="SourceTextBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextBrush}"
                                 FontSize="13"
                                 TextWrapping="Wrap"
                                 IsReadOnly="False"
                                 AcceptsReturn="True"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- תוצאת תרגום -->
            <Border Grid.Row="2"
                    Background="{StaticResource CardBrush}"
                    Margin="14,6,14,6"
                    CornerRadius="8"
                    Padding="12,10">
                <Grid>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="תרגום"
                                       FontSize="10"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="DetectedLangLabel"
                                       Text=""
                                       FontSize="10"
                                       Foreground="{StaticResource SubtleTextBrush}"/>
                        </Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="180">
                            <TextBox x:Name="TranslatedTextBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource TextBrush}"
                                     FontSize="15"
                                     TextWrapping="Wrap"
                                     IsReadOnly="True"
                                     Text=""/>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- אינדיקטור טעינה -->
                    <StackPanel x:Name="LoadingPanel"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="Visible">
                        <TextBlock Text="⏳"
                                   FontSize="28"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="מתרגם..."
                                   FontSize="12"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- שורת פעולות תחתונה -->
            <Grid Grid.Row="3" Margin="14,6,14,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- בחירת שפת יעד -->
                <ComboBox x:Name="TargetLangCombo"
                          Grid.Column="0"
                          Width="120"
                          Height="30"
                          Background="{StaticResource CardBrush}"
                          Foreground="{StaticResource TextBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          SelectionChanged="TargetLangCombo_SelectionChanged"/>

                <!-- כפתורים -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Style="{StaticResource IconButton}"
                            Content="📋 העתק"
                            Click="CopyButton_Click"
                            Margin="0,0,6,0"/>
                    <Button Style="{StaticResource IconButton}"
                            Content="🔄 תרגם שוב"
                            Click="RetranslateButton_Click"
                            Margin="0,0,6,0"/>
                    <Button Style="{StaticResource IconButton}"
                            Content="⚙️ הגדרות"
                            Click="SettingsButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
