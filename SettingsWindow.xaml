<Window x:Class="ClickToTranslate.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="הגדרות ClickToTranslate" Height="560" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        Foreground="#CDD6F4"
        FlowDirection="RightToLeft"
        FontSize="13">

    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="CardBrush" Color="#2A2A3C"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#89B4FA"/>
        <SolidColorBrush x:Key="TextBrush" Color="#CDD6F4"/>
        <SolidColorBrush x:Key="SubtleBrush" Color="#9399B2"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#45475A"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Height" Value="32"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Margin" Value="0,6,0,6"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="⚙️ הגדרות"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- מנוע תרגום -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="מנוע תרגום" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox x:Name="EngineCombo">
                            <ComboBoxItem Content="Google Translate (חינמי, ללא מפתח)" Tag="Google"/>
                            <ComboBoxItem Content="DeepL (איכותי, דורש API key)" Tag="DeepL"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- שפת יעד -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="שפת יעד ברירת מחדל" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox x:Name="TargetLangCombo"/>
                        <TextBlock Text="זו השפה שאליה יתורגם טקסט כברירת מחדל."
                                   Foreground="{StaticResource SubtleBrush}"
                                   FontSize="11"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- DeepL API Key -->
                <Border Style="{StaticResource CardBorder}" x:Name="DeepLCard">
                    <StackPanel>
                        <TextBlock Text="מפתח API של DeepL" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="DeepLKeyBox"/>
                        <CheckBox x:Name="DeepLFreeTierCheck"
                                  Content="השתמש ב-DeepL Free (api-free.deepl.com)"
                                  Margin="0,8,0,0"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{StaticResource SubtleBrush}"
                                   FontSize="11"
                                   Margin="0,6,0,0">
                            ניתן לקבל מפתח חינמי בכתובת: deepl.com/pro-api
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- הגדרות חלונית -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="הגדרות חלונית התרגום" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <TextBlock Text="מיקום על המסך:" Margin="0,4,0,4"/>
                        <ComboBox x:Name="PositionCombo">
                            <ComboBoxItem Content="ליד סמן העכבר" Tag="cursor"/>
                            <ComboBoxItem Content="מרכז המסך" Tag="center"/>
                            <ComboBoxItem Content="פינה ימנית-עליונה" Tag="top-right"/>
                        </ComboBox>

                        <CheckBox x:Name="AutoCopyCheck"
                                  Content="העתק תרגום אוטומטית ללוח"
                                  Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <!-- רישום הפרוטוקול -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="אינטגרציה עם המערכת" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock x:Name="RegisterStatusText"
                                   Foreground="{StaticResource SubtleBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="רשום פרוטוקול"
                                    Click="RegisterButton_Click"
                                    Margin="0,0,8,0"/>
                            <Button Content="בטל רישום"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="UnregisterButton_Click"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{StaticResource SubtleBrush}"
                                   FontSize="11"
                                   Margin="0,8,0,0">
                            רישום ה-scheme clicktotranslate:// מאפשר ל-Click to Do לפתוח את התוכנה. לא דורש הרשאות אדמין.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="SettingsPathText"
                           Foreground="{StaticResource SubtleBrush}"
                           FontSize="10"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- כפתורי תחתית -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="0,16,0,0">
            <Button Content="שמור"
                    Click="SaveButton_Click"
                    Margin="0,0,10,0"/>
            <Button Content="ביטול"
                    Style="{StaticResource SecondaryButton}"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
