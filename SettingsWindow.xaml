<Window x:Class="ClickToTranslate.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="הגדרות ClickToTranslate" Height="620" Width="520"
        WindowStartupLocation="CenterScreen"
        Icon="icon.ico"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}"
        FlowDirection="RightToLeft"
        FontSize="13"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <!-- סגנונות ספציפיים לחלון ההגדרות בלבד -->

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="LineHeight" Value="16"/>
        </Style>

        <!-- כפתור ראשי -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource OnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentDarkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- כפתור משני -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource CardHoverBrush}"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource BorderHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- כותרת ראשית -->
        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="הגדרות"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"/>
            <TextBlock Text="ClickToTranslate · תרגום מהיר למסך"
                       FontSize="12"
                       Foreground="{StaticResource SubtleTextBrush}"
                       Margin="0,2,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
            <StackPanel>

                <!-- מנוע תרגום -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="מנוע תרגום" Style="{StaticResource SectionTitle}"/>
                        <ComboBox x:Name="EngineCombo">
                            <ComboBoxItem Content="Google Translate · חינמי, ללא מפתח" Tag="Google"/>
                            <ComboBoxItem Content="DeepL · איכותי, דורש API key" Tag="DeepL"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- שפת יעד -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="שפת יעד ברירת מחדל" Style="{StaticResource SectionTitle}"/>
                        <ComboBox x:Name="TargetLangCombo" MaxDropDownHeight="320"/>
                        <TextBlock Text="זו השפה שאליה יתורגם טקסט כברירת מחדל."
                                   Style="{StaticResource HintText}"/>
                    </StackPanel>
                </Border>

                <!-- DeepL API Key -->
                <Border Style="{StaticResource CardBorder}" x:Name="DeepLCard">
                    <StackPanel>
                        <TextBlock Text="מפתח API של DeepL" Style="{StaticResource SectionTitle}"/>
                        <TextBox x:Name="DeepLKeyBox"/>
                        <CheckBox x:Name="DeepLFreeTierCheck"
                                  Content="השתמש ב-DeepL Free (api-free.deepl.com)"
                                  Margin="0,14,0,0"/>
                        <TextBlock Text="ניתן לקבל מפתח חינמי בכתובת: deepl.com/pro-api"
                                   Style="{StaticResource HintText}"/>
                    </StackPanel>
                </Border>

                <!-- הגדרות חלונית -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="חלונית התרגום" Style="{StaticResource SectionTitle}"/>

                        <TextBlock Text="מיקום על המסך"
                                   FontSize="12"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   Margin="0,0,0,6"/>
                        <ComboBox x:Name="PositionCombo">
                            <ComboBoxItem Content="ליד סמן העכבר" Tag="cursor"/>
                            <ComboBoxItem Content="מרכז המסך" Tag="center"/>
                            <ComboBoxItem Content="פינה ימנית-עליונה" Tag="top-right"/>
                            <ComboBoxItem Content="פינה שמאלית-עליונה" Tag="top-left"/>
                        </ComboBox>

                        <CheckBox x:Name="AutoCopyCheck"
                                  Content="העתק תרגום אוטומטית ללוח"
                                  Margin="0,14,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ערכת נושא -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="ערכת נושא" Style="{StaticResource SectionTitle}"/>
                        <ComboBox x:Name="ThemeCombo">
                            <ComboBoxItem Content="לפי מצב המערכת" Tag="system"/>
                            <ComboBoxItem Content="בהירה" Tag="light"/>
                            <ComboBoxItem Content="כהה" Tag="dark"/>
                        </ComboBox>
                        <TextBlock Text="השינוי יחול בפעם הבאה שחלון תרגום יפתח."
                                   Style="{StaticResource HintText}"/>
                    </StackPanel>
                </Border>

                <!-- רישום הפרוטוקול -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="אינטגרציה עם המערכת" Style="{StaticResource SectionTitle}"/>
                        <Border x:Name="StatusBanner"
                                Background="{StaticResource BannerBrush}"
                                CornerRadius="6"
                                Padding="12,8"
                                Margin="0,0,0,12">
                            <TextBlock x:Name="RegisterStatusText"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       LineHeight="18"/>
                        </Border>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="רשום פרוטוקול"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="RegisterButton_Click"
                                    Margin="0,0,8,0"/>
                            <Button Content="בטל רישום"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="UnregisterButton_Click"/>
                        </StackPanel>
                        <TextBlock Text="רישום ה-scheme clicktotranslate:// מאפשר ל-Click to Do לפתוח את התוכנה. לא דורש הרשאות אדמין."
                                   Style="{StaticResource HintText}"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="SettingsPathText"
                           Foreground="{StaticResource SubtleTextBrush}"
                           FontSize="10"
                           TextWrapping="Wrap"
                           Margin="2,4,2,0"
                           Opacity="0.7"/>
            </StackPanel>
        </ScrollViewer>

        <!-- כפתורי תחתית -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="0,16,0,0">
            <Button Content="שמור"
                    Style="{StaticResource PrimaryButton}"
                    Click="SaveButton_Click"
                    Margin="0,0,10,0"
                    MinWidth="110"/>
            <Button Content="ביטול"
                    Style="{StaticResource SecondaryButton}"
                    Click="CancelButton_Click"
                    MinWidth="110"/>
        </StackPanel>
    </Grid>
</Window>
